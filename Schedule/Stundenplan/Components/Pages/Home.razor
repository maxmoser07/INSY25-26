@page "/"
@using Microsoft.EntityFrameworkCore
@using Schedule.Context
@inject ScheduleContext Db
@rendermode InteractiveServer

<PageTitle>Stundenplan Verwaltung</PageTitle>

<div class="container mt-4">
    @* --- FORM SECTION: Add or Edit --- *@
    <div class="card shadow mb-5">
        <div class="card-header @(editingLesson.Id == 0 ? "bg-primary" : "bg-warning") text-white">
            <h5 class="mb-0">@(editingLesson.Id == 0 ? "Neuen Eintrag hinzufügen" : "Eintrag bearbeiten")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="editingLesson" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Lehrer</label>
                        <InputSelect ValueExpression="@(()=>editingLesson.Tid)" 
                                     Value="@editingLesson.Tid" 
                                     ValueChanged="@((int value) => OnTeacherChanged(value))" 
                                     class="form-control">
                            <option value="0">-- Lehrer wählen --</option>
                            @foreach (var t in allTeachers)
                            {
                                <option value="@t.Id">@t.Abbr</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fach</label>
                        <InputSelect ValueExpression="@(()=>editingLesson.Sid)" 
                                     Value="@editingLesson.Sid" 
                                     ValueChanged="@((int value) => OnSubjectChanged(value))"
                                     class="form-control" disabled="@(editingLesson.Tid == 0)">
                            <option value="0">-- Fach wählen --</option>
                            @foreach (var s in filteredSubjects)
                            {
                                <option value="@s.Id">@s.Desc</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Klasse</label>
                        <InputSelect @bind-Value="editingLesson.Cid" class="form-control" disabled="@(editingLesson.Sid == 0)">
                            <option value="0">-- Klasse wählen --</option>
                            @foreach (var c in filteredClasses)
                            {
                                <option value="@c.Id">@c.Abbr</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Wochentag</label>
                        <InputSelect @bind-Value="editingLesson.Day" class="form-control">
                            @foreach (var day in Enum.GetValues<WeekDay>())
                            {
                                <option value="@day">@day.ToString()</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Stunde</label>
                        <InputText @bind-Value="editingLesson.Hour" class="form-control" placeholder="z.B. 1. Stunde" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    @if (editingLesson.Id != 0)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Abbrechen</button>
                    }
                    <button type="submit" class="btn @(editingLesson.Id == 0 ? "btn-success" : "btn-warning")" 
                            disabled="@(editingLesson.Cid == 0)">
                        @(editingLesson.Id == 0 ? "Speichern" : "Änderungen übernehmen")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    @* --- TABLE SECTION: Overview --- *@
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Aktueller Stundenplan</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tag</th>
                        <th>Stunde</th>
                        <th>Klasse</th>
                        <th>Lehrer</th>
                        <th>Fach</th>
                        <th class="text-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lessons == null)
                    {
                        <tr><td colspan="6" class="text-center p-4">Lade Daten...</td></tr>
                    }
                    else if (!lessons.Any())
                    {
                        <tr><td colspan="6" class="text-center p-4 text-muted">Keine Einträge vorhanden.</td></tr>
                    }
                    else
                    {
                        @foreach (var lesson in lessons)
                        {
                            <tr class="@(editingLesson.Id == lesson.Id ? "table-warning" : "")">
                                <td><span class="badge bg-info text-dark">@lesson.Day</span></td>
                                <td>@lesson.Hour</td>
                                <td><strong>@lesson.Class?.Abbr</strong></td>
                                <td>@lesson.Teacher?.Abbr</td>
                                <td>@lesson.Subject?.Desc</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => StartEdit(lesson)">
                                        Bearbeiten
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLesson(lesson.Id)">
                                        Löschen
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Unterricht>? lessons;
    private List<Teacher> allTeachers = new();
    private List<Subject> filteredSubjects = new();
    private List<Class> filteredClasses = new();
    
    // The model used by the form
    private Unterricht editingLesson = new() { Day = WeekDay.Monday };

    protected override async Task OnInitializedAsync()
    {
        allTeachers = await Db.Teachers.OrderBy(t => t.Abbr).ToListAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        lessons = await Db.Lessons
            .Include(u => u.Teacher)
            .Include(u => u.Class)
            .Include(u => u.Subject)
            .OrderBy(u => u.Day)
            .ThenBy(u => u.Hour)
            .ToListAsync();
    }

    private async Task StartEdit(Unterricht lesson)
    {
        // Load the lesson into the form
        editingLesson = lesson;

        // Manually trigger the dropdown filters to show the current Subject and Class options [cite: 13, 17]
        await OnTeacherChanged(lesson.Tid, resetChildren: false);
        await OnSubjectChanged(lesson.Sid, resetChildren: false);
        
        // Restore the original selections that the filter methods might have wiped
        editingLesson.Sid = lesson.Sid;
        editingLesson.Cid = lesson.Cid;
    }

    private void CancelEdit()
    {
        editingLesson = new() { Day = WeekDay.Monday };
        filteredSubjects.Clear();
        filteredClasses.Clear();
    }

    private async Task OnTeacherChanged(int teacherId, bool resetChildren = true)
    {
        editingLesson.Tid = teacherId;
        if (resetChildren) {
            editingLesson.Sid = 0;
            editingLesson.Cid = 0;
            filteredClasses.Clear();
        }

        if (teacherId > 0)
        {
            filteredSubjects = await Db.TeacherSubjects
                .Where(ts => ts.Tid == teacherId)
                .Select(ts => ts.Subject)
                .ToListAsync();
        }
        else
        {
            filteredSubjects.Clear();
        }
    }

    private async Task OnSubjectChanged(int subjectId, bool resetChildren = true)
    {
        editingLesson.Sid = subjectId;
        if (resetChildren) {
            editingLesson.Cid = 0;
        }

        if (subjectId > 0)
        {
            filteredClasses = await Db.ClassSubjects
                .Where(cs => cs.Sid == subjectId)
                .Select(cs => cs.Class)
                .ToListAsync();
        }
        else
        {
            filteredClasses.Clear();
        }
    }

    private async Task HandleSubmit()
    {
        try 
        {
            if (editingLesson.Id == 0)
            {
                Db.Lessons.Add(editingLesson); 
            }
            else
            {
                Db.Lessons.Update(editingLesson);
            }

            await Db.SaveChangesAsync();
            CancelEdit();
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task DeleteLesson(int id)
    {
        try 
        {
            var lesson = await Db.Lessons.FindAsync(id);
            if (lesson != null)
            {
                Db.Lessons.Remove(lesson);
                await Db.SaveChangesAsync();
                await LoadData(); 
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Löschen: {ex.Message}");
        }
    }
}