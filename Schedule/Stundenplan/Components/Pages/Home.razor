@page "/"
@using Microsoft.EntityFrameworkCore
@using Schedule.Context
@inject ScheduleContext Db
@rendermode  InteractiveServer
<PageTitle>Übersicht - Stundenplan</PageTitle>

<div class="container mt-4">
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6>Lehrer</h6>
                    <p class="h2">@teacherCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-primary">
                <div class="card-body">
                    <h6>Unterrichtsstunden</h6>
                    <p class="h2 text-primary">@lessonCount</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Aktueller Stundenplan</h5>
            <a href="add-lesson" class="btn btn-sm btn-success">Eintrag hinzufügen</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tag</th>
                        <th>Stunde</th>
                        <th>Klasse</th>
                        <th>Lehrer</th>
                        <th>Fach</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lessons == null)
                    {
                        <tr><td colspan="6" class="text-center p-4">Lade Daten...</td></tr>
                    }
                    else if (!lessons.Any())
                    {
                        <tr><td colspan="6" class="text-center p-4 text-muted">Keine Einträge vorhanden.</td></tr>
                    }
                    else
                    {
                        @foreach (var lesson in lessons)
                        {
                            <tr>
                                <td><span class="badge bg-info text-dark">@lesson.Day</span></td>
                                <td>@lesson.Hour</td>
                                <td><strong>@lesson.Class?.Abbr</strong></td>
                                <td>@lesson.Teacher?.Abbr</td>
                                <td>@lesson.Subject?.Desc</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLesson(lesson.Id)">
                                        Löschen
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private int teacherCount;
    private int lessonCount; // usw.
    private List<Unterricht>? lessons;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Statistiken laden
        teacherCount = await Db.Teachers.CountAsync();
        lessonCount = await Db.Lessons.CountAsync();

        // Unterricht mit Relationen laden (Wichtig: .Include nutzen!)
        lessons = await Db.Lessons
            .Include(u => u.Teacher)
            .Include(u => u.Class)
            .Include(u => u.Subject)
            .OrderBy(u => u.Day)
            .ThenBy(u => u.Hour)
            .ToListAsync();
    }

    private async Task DeleteLesson(int id)
    {
        try 
        {
            var lesson = await Db.Lessons.FindAsync(id);
            if (lesson != null)
            {
                Db.Lessons.Remove(lesson);
                await Db.SaveChangesAsync();
                await LoadData(); 
            }
        }
        catch (Exception ex)
        {
            // Wenn der Button nach Schritt 1 klickt, aber nichts passiert, 
            // erscheint hier die Fehlermeldung (z.B. Foreign Key Constraint).
            Console.WriteLine($"Fehler beim Löschen: {ex.Message}");
        }
    }
}